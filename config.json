{
  "presets": {
    "help": "Commands:\n• `!<cmd>` — run shell command\n• `?<question>` — ask Claude\n• Preset keywords: ping, status, help",
    "status": "Bot is running.",
    "ping": "pong"
  },
  "proxy": "http://127.0.0.1:2080",
  "archive_dir": "telegram_archive",
  "notify_port": 8765,
  "poll_interval": 2,
  "shell_timeout": 30,
  "shell_output_max_chars": 3000,
  "claude_backend": "api",
  "claude_model": "claude-sonnet-4-6",
  "claude_max_tokens": 4096,
  "claude_history_turns": 24,
  "claude_cli_timeout": 120,
  "claude_allowed_commands": [],
  "privileged_claude_model": "claude-sonnet-4-6",
  "privileged_claude_max_tokens": 4096,
  "privileged_claude_history_turns": 24,
  "privileged_claude_max_rounds": 20,
  "privileged_claude_shell_timeout": 60,
  "privileged_shell_whitelist": [
    "df -h"
  ],
  "video_download_dir": "video_downloads",
  "video_download_cookies_bilibili": "~/claude-workspace/telegram_monitor/bilibili_cookie.txt",
  "video_download_cookies_douyin": "douyin_cookies.txt",
  "video_download_timeout": 600,
  "video_download_transcode_threads": 1,
  "email_enabled": true,
  "email_credentials_path": "email_credentials.json",
  "email_state_path": "email_state.json",
  "email_digest_interval_hours": 6,
  "email_check_interval": 30,
  "email_urgent_keywords": [
    "urgent",
    "emergency",
    "action required",
    "紧急",
    "重要"
  ],
  "email_claude_model": "claude-sonnet-4-6",
  "email_claude_max_tokens": 200,
  "bilibili_fav_enabled": true,
  "bilibili_fav_state_path": "bilibili_fav_state.json",
  "bilibili_fav_check_interval": 300,
  "bilibili_fav_download_dir": "video_downloads/bilibili_fav",
  "bilibili_fav_download_timeout": 600,
  "bilibili_fav_initial_download_limit": 0,
  "bilibili_fav_nas_enabled": true,
  "bilibili_fav_nas_host": "nas",
  "bilibili_fav_nas_dest_dir": "/volume1/Share/BilibiliVideos",
  "bilibili_up_enabled": true,
  "bilibili_up_state_path": "bilibili_up_state.json",
  "bilibili_up_check_interval": 300,
  "bilibili_up_download_dir": "video_downloads/bilibili_up",
  "bilibili_up_download_timeout": 600,
  "telegram_api_base": "http://127.0.0.1:8081",
  "telegram_local_mode": true,
  "telegram_upload_limit_mb": 2000
}

{
  "presets": {
    "help": "Commands:\n• `!<cmd>` — run shell command\n• `?<question>` — ask Claude\n• Preset keywords: ping, status, help",
    "status": "Bot is running.",
    "ping": "pong"
  },
  "proxy": "http://127.0.0.1:2080",
  "archive_dir": "~/telegram_archive",
  "notify_port": 8765,
  "poll_interval": 2,
  "shell_timeout": 30,
  "shell_output_max_chars": 3000,
  "claude_backend": "api",
  "claude_model": "claude-sonnet-4-6",
  "claude_max_tokens": 4096,
  "claude_history_turns": 24,
  "claude_cli_timeout": 120,
  "claude_allowed_commands": [],
  "privileged_claude_model": "claude-sonnet-4-6",
  "privileged_claude_max_tokens": 4096,
  "privileged_claude_history_turns": 24,
  "privileged_claude_max_rounds": 20,
  "privileged_claude_shell_timeout": 60,
  "privileged_shell_whitelist": [
    "df -h"
  ],
  "video_download_dir": "~/video_downloads",
  "video_download_cookies_bilibili": "",
  "video_download_cookies_douyin": "~/douyin_cookies.txt",
  "video_download_timeout": 600
}

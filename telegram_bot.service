[Unit]
Description=Telegram Bot Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=huzhuoliang
EnvironmentFile=/etc/telegram-bot/project.env
ExecStart=/bin/sh -c 'cd ${PROJECT_DIR} && exec /usr/bin/python3 bot.py'
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

# To use claude_backend="api", create /etc/telegram_bot.env (chmod 600) with:
#   ANTHROPIC_API_KEY=sk-ant-...
# Then uncomment the line below:
# EnvironmentFile=/etc/telegram_bot.env

[Install]
WantedBy=multi-user.target
